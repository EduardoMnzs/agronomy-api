# App
APP_NAME=Agronomy API
DEBUG=false

# Postgres / Redis credentials
# Gere senhas fortes:  python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_USER=agronomy
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agronomy
REDIS_PASSWORD=change-me

# Database
DATABASE_URL=postgresql+psycopg2://agronomy:change-me@localhost:5432/agronomy

# JWT — gere com:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# A app recusa o boot se DEBUG=false e SECRET_KEY estiver com valor default.
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_DAYS=30

# CORS — lista separada por vírgula, sem "*"
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Allowlist opcional de modelos LLM aceitos no campo `model` do POST /query
# (vazio = ignora o param para usuários não-admin e usa o default do servidor)
ALLOWED_LLM_MODELS=

# Caddy / TLS (produção)
PUBLIC_DOMAIN=localhost
ACME_EMAIL=admin@example.com

# Gunicorn workers (default 4 em produção, 2 em dev)
GUNICORN_WORKERS=4

# LLM — escolha um provider
LLM_MODEL=gpt-4o-2024-11-20
# LLM_MODEL=azure/gpt-4o-pageindex
# LLM_MODEL=gemini/gemini-1.5-pro
# LLM_MODEL=anthropic/claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI (se usar azure/...)
AZURE_API_KEY=
AZURE_API_BASE=https://seu-recurso.openai.azure.com
AZURE_API_VERSION=2024-02-01

# Google Gemini (se usar gemini/...)
GEMINI_API_KEY=

# Anthropic (se usar anthropic/...)
ANTHROPIC_API_KEY=

# Email (Resend) — necessário para reset de senha e notificações de acesso
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@seu-dominio.com

# URL pública do frontend — usada nos links dos emails
APP_BASE_URL=http://localhost:5173

# Redis (com senha)
REDIS_URL=redis://:change-me@localhost:6379
