# App
APP_NAME=Agronomy API
DEBUG=false

# Database
DATABASE_URL=postgresql://agronomy:agronomy@localhost:5432/agronomy

# JWT — troque por uma string aleatória segura em produção
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — escolha um provider
LLM_MODEL=gpt-4o-2024-11-20
# LLM_MODEL=azure/gpt-4o-pageindex
# LLM_MODEL=gemini/gemini-1.5-pro
# LLM_MODEL=anthropic/claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI (se usar azure/...)
AZURE_API_KEY=
AZURE_API_BASE=https://seu-recurso.openai.azure.com
AZURE_API_VERSION=2024-02-01

# Google Gemini (se usar gemini/...)
GEMINI_API_KEY=

# Anthropic (se usar anthropic/...)
ANTHROPIC_API_KEY=
